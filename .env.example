# =============================================================================
# .env.example — environment variable template for docker-compose.yml
#
# Copy this file to .env and fill in real values before running the stack:
#
#   cp .env.example .env
#
# Or generate a cryptographically random secret in one command:
#
#   echo "JWT_SECRET=$(openssl rand -hex 32)" > .env
#
# .env is already listed in .gitignore — never commit real secrets.
# =============================================================================

# ── JWT signing secret ────────────────────────────────────────────────────────
# Must be identical on all five application services:
#   auth-service     → signs tokens with this key
#   gateway-service  → verifies tokens with this key
#   order-service    \
#   product-service   → verify tokens with this key
#   payment-service  /
#
# Requirements:
#   • Minimum 32 ASCII characters (256 bits) for HS256
#   • No spaces; URL-safe characters recommended
#   • Generate with: openssl rand -hex 32
JWT_SECRET=order-processing-default-dev-secret-key-must-be-32chars
