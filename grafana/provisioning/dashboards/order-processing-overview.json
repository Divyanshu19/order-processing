{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "description": "Order Processing System — custom Micrometer metrics: order placements, saga step durations, circuit breaker state, payment and stock reservation outcomes.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "🛒 Order Service — Placement & Saga",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Rate of successfully placed orders per second (5 m window).",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          },
          "unit": "ops"
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "id": 1,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "title": "Order Placement Rate (ops/s)",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "rate(orders_placed_total{application=\"order-service\"}[5m])",
          "legendFormat": "placed/s",
          "refId": "A"
        }
      ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Rate of failed order creation attempts per second.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.1 },
              { "color": "red", "value": 1 }
            ]
          },
          "unit": "ops"
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "id": 2,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "title": "Order Failure Rate (ops/s)",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "rate(orders_placed_failed_total{application=\"order-service\"}[5m])",
          "legendFormat": "failed/s",
          "refId": "A"
        }
      ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Current number of orders in PENDING state (in-memory approximation).",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 200 }
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "id": 3,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "title": "In-Flight Orders (PENDING)",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "saga_orders_inflight{application=\"order-service\"}",
          "legendFormat": "inflight",
          "refId": "A"
        }
      ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Saga success rate = confirmed / (confirmed + cancelled + failed).",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.7 },
              { "color": "green", "value": 0.9 }
            ]
          },
          "unit": "percentunit",
          "min": 0,
          "max": 1
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "id": 4,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "title": "Saga Success Rate",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "rate(saga_outcome_total{application=\"order-service\",outcome=\"confirmed\"}[5m]) / (rate(saga_outcome_total{application=\"order-service\"}[5m]) > 0)",
          "legendFormat": "success rate",
          "refId": "A"
        }
      ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "95th-percentile order creation latency (product fetch + DB write + Kafka publish).",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 500 },
              { "color": "red", "value": 2000 }
            ]
          },
          "unit": "ms"
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "id": 5,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "title": "Order Create p95 Latency",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.95, rate(order_create_duration_seconds_bucket{application=\"order-service\"}[5m])) * 1000",
          "legendFormat": "p95 ms",
          "refId": "A"
        }
      ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Rate of saga terminal outcomes over time (confirmed, cancelled, failed).",
      "fieldConfig": {
        "defaults": { "unit": "ops" },
        "overrides": [
          { "matcher": { "id": "byName", "options": "confirmed" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "cancelled" },  "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "failed" },     "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 5 },
      "id": 6,
      "options": { "tooltip": { "mode": "multi" } },
      "title": "Saga Outcome Rates",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "rate(saga_outcome_total{application=\"order-service\",outcome=\"confirmed\"}[5m])",
          "legendFormat": "confirmed",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "rate(saga_outcome_total{application=\"order-service\",outcome=\"cancelled\"}[5m])",
          "legendFormat": "cancelled",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "rate(saga_outcome_total{application=\"order-service\",outcome=\"failed\"}[5m])",
          "legendFormat": "failed",
          "refId": "C"
        }
      ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "p50 and p95 latency of each saga step × outcome combination.",
      "fieldConfig": { "defaults": { "unit": "ms" } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 5 },
      "id": 7,
      "options": { "tooltip": { "mode": "multi" } },
      "title": "Saga Step Duration (p50 / p95)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.50, rate(saga_step_duration_seconds_bucket{application=\"order-service\"}[5m])) * 1000",
          "legendFormat": "p50 {{step}}/{{outcome}}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.95, rate(saga_step_duration_seconds_bucket{application=\"order-service\"}[5m])) * 1000",
          "legendFormat": "p95 {{step}}/{{outcome}}",
          "refId": "B"
        }
      ]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 13 },
      "id": 101,
      "title": "⚡ Circuit Breaker — productService",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Circuit breaker state: 0=CLOSED (healthy), 1=OPEN (failing), 2=HALF_OPEN (probing). Alert when value = 1 for > 30 s.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [
            { "options": { "0": { "text": "CLOSED",    "color": "green"  } }, "type": "value" },
            { "options": { "1": { "text": "OPEN",      "color": "red"    } }, "type": "value" },
            { "options": { "2": { "text": "HALF_OPEN", "color": "yellow" } }, "type": "value" }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 2 },
              { "color": "red",    "value": 1 }
            ]
          },
          "min": 0,
          "max": 2
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 14 },
      "id": 10,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" },
      "title": "CB State — productService",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "circuit_breaker_state{application=\"order-service\",name=\"productService\"}",
          "legendFormat": "state",
          "refId": "A"
        }
      ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Total CLOSED→OPEN transitions (circuit trips). Increase means instability.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red",   "value": 1 }
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 14 },
      "id": 11,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "title": "CB Trips (CLOSED→OPEN)",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "circuit_breaker_transitions_total{application=\"order-service\",name=\"productService\",from=\"CLOSED\",to=\"OPEN\"}",
          "legendFormat": "trips",
          "refId": "A"
        }
      ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Total OPEN→HALF_OPEN probe transitions (recovery attempts).",
      "fieldConfig": { "defaults": { "unit": "short" } },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 14 },
      "id": 12,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" },
      "title": "CB Recoveries (OPEN→HALF_OPEN)",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "circuit_breaker_transitions_total{application=\"order-service\",name=\"productService\",from=\"OPEN\",to=\"HALF_OPEN\"}",
          "legendFormat": "recoveries",
          "refId": "A"
        }
      ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Circuit breaker state history over time. A step up to 1 = OPEN, back down to 0 = healed.",
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 20, "steppedLine": true },
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red",   "value": 1 }
            ]
          }
        }
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 18 },
      "id": 13,
      "options": { "tooltip": { "mode": "multi" } },
      "title": "Circuit Breaker State History",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "circuit_breaker_state{application=\"order-service\"}",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 26 },
      "id": 102,
      "title": "💳 Payment Service",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Breakdown of payment outcomes over time.",
      "fieldConfig": {
        "defaults": { "unit": "ops" },
        "overrides": [
          { "matcher": { "id": "byName", "options": "success"  }, "properties": [{ "id": "color", "value": { "fixedColor": "green",  "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "declined" }, "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "error"    }, "properties": [{ "id": "color", "value": { "fixedColor": "red",    "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "skipped"  }, "properties": [{ "id": "color", "value": { "fixedColor": "blue",   "mode": "fixed" } }] }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 27 },
      "id": 20,
      "options": { "tooltip": { "mode": "multi" } },
      "title": "Payment Outcome Rates",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "rate(payments_processed_total{application=\"payment-service\",outcome=\"success\"}[5m])",
          "legendFormat": "success",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "rate(payments_processed_total{application=\"payment-service\",outcome=\"declined\"}[5m])",
          "legendFormat": "declined",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "rate(payments_processed_total{application=\"payment-service\",outcome=\"error\"}[5m])",
          "legendFormat": "error",
          "refId": "C"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "rate(payments_processed_total{application=\"payment-service\",outcome=\"skipped\"}[5m])",
          "legendFormat": "skipped",
          "refId": "D"
        }
      ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Payment processing latency at p50, p95, p99.",
      "fieldConfig": { "defaults": { "unit": "ms" } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 27 },
      "id": 21,
      "options": { "tooltip": { "mode": "multi" } },
      "title": "Payment Processing Duration",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.50, rate(payment_processing_duration_seconds_bucket{application=\"payment-service\"}[5m])) * 1000",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.95, rate(payment_processing_duration_seconds_bucket{application=\"payment-service\"}[5m])) * 1000",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.99, rate(payment_processing_duration_seconds_bucket{application=\"payment-service\"}[5m])) * 1000",
          "legendFormat": "p99",
          "refId": "C"
        }
      ]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 35 },
      "id": 103,
      "title": "📦 Product Service — Stock Reservations",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Stock reservation outcome rates.",
      "fieldConfig": {
        "defaults": { "unit": "ops" },
        "overrides": [
          { "matcher": { "id": "byName", "options": "success"            }, "properties": [{ "id": "color", "value": { "fixedColor": "green",  "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "insufficient_stock" }, "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "product_not_found"  }, "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "error"              }, "properties": [{ "id": "color", "value": { "fixedColor": "red",    "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "skipped"            }, "properties": [{ "id": "color", "value": { "fixedColor": "blue",   "mode": "fixed" } }] }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 36 },
      "id": 30,
      "options": { "tooltip": { "mode": "multi" } },
      "title": "Stock Reservation Outcome Rates",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "rate(stock_reservations_total{application=\"product-service\",outcome=\"success\"}[5m])",
          "legendFormat": "success",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "rate(stock_reservations_total{application=\"product-service\",outcome=\"insufficient_stock\"}[5m])",
          "legendFormat": "insufficient_stock",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "rate(stock_reservations_total{application=\"product-service\",outcome=\"product_not_found\"}[5m])",
          "legendFormat": "product_not_found",
          "refId": "C"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "rate(stock_reservations_total{application=\"product-service\",outcome=\"error\"}[5m])",
          "legendFormat": "error",
          "refId": "D"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "rate(stock_reservations_total{application=\"product-service\",outcome=\"skipped\"}[5m])",
          "legendFormat": "skipped",
          "refId": "E"
        }
      ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Stock reservation handler latency at p50, p95, p99.",
      "fieldConfig": { "defaults": { "unit": "ms" } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 36 },
      "id": 31,
      "options": { "tooltip": { "mode": "multi" } },
      "title": "Stock Reservation Duration",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.50, rate(stock_reservation_duration_seconds_bucket{application=\"product-service\"}[5m])) * 1000",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.95, rate(stock_reservation_duration_seconds_bucket{application=\"product-service\"}[5m])) * 1000",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.99, rate(stock_reservation_duration_seconds_bucket{application=\"product-service\"}[5m])) * 1000",
          "legendFormat": "p99",
          "refId": "C"
        }
      ]
    }

  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["order-processing", "micrometer", "saga", "circuit-breaker"],
  "templating": {
    "list": [
      {
        "current": { "selected": false, "text": "Prometheus", "value": "Prometheus" },
        "hide": 0,
        "includeAll": false,
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource",
        "label": "Data Source"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Order Processing — Micrometer Metrics",
  "uid": "order-processing-metrics-v1",
  "version": 1
}
