<?xml version="1.0" encoding="UTF-8"?>
<!--
  Logback configuration for auth-service.

  Two appenders selected by Spring profile:
    default / dev  → CONSOLE_TEXT  (human-readable, easy to grep locally)
    json / prod    → CONSOLE_JSON  (LogstashEncoder, one JSON object per line)

  Every log line automatically includes:
    • traceId  — populated by micrometer-tracing-bridge-brave
    • spanId   — populated by micrometer-tracing-bridge-brave
    • service  — "auth-service" (from spring.application.name)

  JSON output example:
  {
    "@timestamp": "2024-05-01T12:34:56.789Z",
    "level":      "INFO",
    "logger":     "c.o.p.auth.controller.AuthController",
    "message":    "Login successful for user: admin",
    "service":    "auth-service",
    "traceId":    "4bf92f3577b34da6a3ce929d0e0e4736",
    "spanId":     "00f067aa0ba902b7"
  }
-->
<configuration>

    <!-- ── Service identity ───────────────────────────────────────────────── -->
    <!-- springProperty must remain at the top level so both profiles can use it -->
    <springProperty name="SERVICE_NAME" source="spring.application.name" defaultValue="auth-service"/>

    <!-- ── Profile: default / dev / test — human-readable text ──────────── -->
    <!--   Appender declared INSIDE the profile so Logback only instantiates  -->
    <!--   it when this profile is active, eliminating the "not referenced"   -->
    <!--   warning for CONSOLE_JSON when running locally without json profile. -->
    <springProfile name="default | dev | test">
        <appender name="CONSOLE_TEXT" class="ch.qos.logback.core.ConsoleAppender">
            <encoder>
                <!-- traceId / spanId come from Micrometer Tracing MDC population.    -->
                <!-- They are "-" at startup/shutdown when no active span is present.  -->
                <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level [${SERVICE_NAME},%mdc{traceId:--},%mdc{spanId:--}] %logger{36} - %msg%n%ex</pattern>
            </encoder>
        </appender>
        <root level="INFO">
            <appender-ref ref="CONSOLE_TEXT"/>
        </root>
        <logger name="com.order.processing.auth" level="DEBUG"/>
    </springProfile>

    <!-- ── Profile: json / prod — structured JSON for log aggregation ────── -->
    <!--   LogstashEncoder serialises every ILoggingEvent to a single-line    -->
    <!--   JSON object. All MDC fields (traceId, spanId) appear automatically. -->
    <springProfile name="json | prod">
        <appender name="CONSOLE_JSON" class="ch.qos.logback.core.ConsoleAppender">
            <encoder class="net.logstash.logback.encoder.LogstashEncoder">
                <fieldNames>
                    <message>message</message>
                    <levelValue>[ignore]</levelValue>
                </fieldNames>
                <customFields>{"service":"${SERVICE_NAME}"}</customFields>
                <throwableConverter class="net.logstash.logback.stacktrace.ShortenedThrowableConverter">
                    <maxDepthPerCause>30</maxDepthPerCause>
                    <rootCauseFirst>true</rootCauseFirst>
                </throwableConverter>
            </encoder>
        </appender>
        <root level="INFO">
            <appender-ref ref="CONSOLE_JSON"/>
        </root>
        <logger name="com.order.processing.auth" level="DEBUG"/>
    </springProfile>

</configuration>
